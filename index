<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Adders Entertainment</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      height: 100%;
      background-color: #0f172a;
      color: #f8fafc;
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      overflow: hidden;
    }

    /* Background video + dark overlay, same treatment as the film school site */
    .bg-video {
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: -2;
    }
    .video-overlay {
      position: fixed;
      inset: 0;
      background: rgba(15, 23, 42, 0.82);
      z-index: -1;
    }

    .heading {
      text-align: center;
      padding: 2.2rem 1rem 0.5rem;
    }
    .heading p {
      color: #94a3b8;
      font-size: clamp(0.85rem, 2vw, 1.05rem);
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    /* Split layout */
    .split {
      display: flex;
      height: calc(100vh - 6rem);
      min-height: 420px;
      width: 100%;
    }
    .panel {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
      padding: 1.5rem;
      text-decoration: none;
      color: inherit;
      position: relative;
      transition: flex 0.5s ease, background 0.4s ease;
      cursor: pointer;
      overflow: hidden;
    }
    /* faint divider between the two sides */
    .panel.pictures { border-right: 1px solid rgba(148, 163, 184, 0.15); }

    /* radial glow that fades in on hover, tinted per brand */
    .panel::before {
      content: '';
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity 0.45s ease;
      z-index: 0;
    }
    .panel.pictures::before {
      background: radial-gradient(circle at center, rgba(201, 162, 77, 0.22), transparent 62%);
    }
    .panel.filmschool::before {
      background: radial-gradient(circle at center, rgba(234, 88, 12, 0.25), transparent 62%);
    }
    .panel:hover::before { opacity: 1; }

    /* On hover the hovered panel grows a touch */
    .split:hover .panel { flex: 0.9; }
    .split:hover .panel:hover { flex: 1.2; }

    .logo-wrap {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      flex: 1;
      width: 100%;
    }
    .panel img {
      max-width: min(78%, 520px);
      max-height: 100%;
      width: auto;
      height: auto;
      object-fit: contain;
      transition: transform 0.4s ease, filter 0.4s ease;
      filter: drop-shadow(0 18px 35px rgba(0, 0, 0, 0.55));
    }
    /* The glow on the logo itself when its panel is hovered */
    .panel.pictures:hover img {
      transform: scale(1.05);
      filter: drop-shadow(0 0 28px rgba(212, 175, 95, 0.85)) drop-shadow(0 0 60px rgba(212, 175, 95, 0.5));
    }
    .panel.filmschool:hover img {
      transform: scale(1.05);
      filter: drop-shadow(0 0 28px rgba(249, 115, 22, 0.9)) drop-shadow(0 0 60px rgba(234, 88, 12, 0.55));
    }

    /* Buttons */
    .enter-btn {
      position: relative;
      z-index: 1;
      display: inline-block;
      font-weight: 700;
      font-size: clamp(0.95rem, 1.6vw, 1.15rem);
      letter-spacing: 0.03em;
      padding: 0.95rem 2.6rem;
      border-radius: 0.7rem;
      color: #ffffff;
      border: 1px solid rgba(255, 255, 255, 0.22);
      transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
      white-space: nowrap;
    }
    .pictures .enter-btn {
      background: linear-gradient(135deg, #d4af5f, #b8893b 55%, #8a6420);
      box-shadow: 0 6px 20px rgba(184, 137, 59, 0.4);
    }
    .filmschool .enter-btn {
      background: linear-gradient(135deg, #fb923c, #ea580c 55%, #c2410c);
      box-shadow: 0 6px 20px rgba(234, 88, 12, 0.45);
    }
    .panel:hover .enter-btn { transform: translateY(-3px) scale(1.04); }
    .pictures:hover .enter-btn { box-shadow: 0 12px 34px rgba(212, 175, 95, 0.7); }
    .filmschool:hover .enter-btn { box-shadow: 0 12px 34px rgba(234, 88, 12, 0.75); }

    footer {
      text-align: center;
      padding: 1rem;
      color: #64748b;
      font-size: 0.8rem;
    }

    /* Stack the two panels on small screens */
    @media (max-width: 760px) {
      html, body { overflow-y: auto; }
      .split {
        flex-direction: column;
        height: auto;
      }
      .panel { padding: 2.5rem 1.5rem; }
      .panel.pictures {
        border-right: none;
        border-bottom: 1px solid rgba(148, 163, 184, 0.15);
      }
      .split:hover .panel,
      .split:hover .panel:hover { flex: 1; }
      .panel img { max-width: 70%; max-height: 320px; }
    }
  </style>
</head>
<body>
  <!-- Background video (same clip as the film school site) -->
  <video class="bg-video" autoplay muted loop playsinline>
    <source src="website-video1.mp4" type="video/mp4">
  </video>
  <div class="video-overlay"></div>

  <div class="heading">
    <p>Choose your destination</p>
  </div>

  <div class="split">
    <a class="panel pictures" href="https://pictures.addersentertainment.org/">
      <div class="logo-wrap">
        <img src="logo-pictures.png" alt="Adders Pictures">
      </div>
      <span class="enter-btn">Enter Adders Pictures</span>
    </a>

    <a class="panel filmschool" href="https://fs.addersentertainment.org/">
      <div class="logo-wrap">
        <img src="logo-film-school.png" alt="Adders Film School">
      </div>
      <span class="enter-btn">Enter Film School</span>
    </a>
  </div>

  <footer>&copy; 2026 Adders Entertainment. All rights reserved.</footer>
</body>
</html>
